# Copy this file to .env and fill in your real values.
# .env is git-ignored — never commit it.

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/esg

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-string

# MinIO object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# Default admin account (created on first startup)
ADMIN_EMPLOYEE_ID=your-admin-id
ADMIN_PASSWORD=your-admin-password

# Default user account (created on first startup)
USER_EMPLOYEE_ID=your-user-id
USER_PASSWORD=your-user-password
